# --- Required ---
# Used to sign JWTs. Generate with: openssl rand -hex 64
JWT_SECRET=change-me-in-production-please

# --- Optional ---
PORT=3000
NODE_ENV=development
DATA_DIR=./data
LOG_LEVEL=info

# JWT lifetime in seconds (default 12h)
JWT_TTL_SECONDS=43200

# --- Active Directory bind password (only if AD enabled in config/auth.json) ---
AD_BIND_PASSWORD=

# --- SMTP password (only if email enabled in config/notifications.json) ---
SMTP_PASSWORD=

# --- SMS adapter credentials (only if SMS enabled, e.g. Twilio) ---
SMS_AUTH_TOKEN=

# --- Inbound email IMAP password (only if incoming.enabled in config/notifications.json) ---
IMAP_PASSWORD=
